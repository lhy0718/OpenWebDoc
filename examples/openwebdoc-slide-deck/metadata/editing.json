{
  "$schema": "https://openwebdoc.org/schemas/htmlx-editing-metadata-v0.1.schema.json",
  "schemaVersion": "0.1.0",
  "mode": "self-editable-document",
  "runtime": "@openwebdoc/runtime",
  "stage": {
    "width": 1600,
    "height": 900,
    "unit": "px",
    "scaleMode": "uniform-fit"
  },
  "blocks": [
    {
      "id": "deck-01-title",
      "type": "heading",
      "selector": "[data-htmlx-block-id=\"deck-01-title\"]",
      "editable": true,
      "textRole": "title",
      "frame": { "x": 112, "y": 194, "width": 1180 },
      "fontSize": 90,
      "lineHeight": 1.02
    },
    {
      "id": "deck-02-principles",
      "type": "figure",
      "selector": "[data-htmlx-block-id=\"deck-02-principles\"]",
      "editable": true,
      "frame": { "x": 108, "y": 340, "width": 1380, "height": 392 },
      "figure": { "variant": "principle-grid", "cardCount": 6 }
    },
    {
      "id": "deck-03-map",
      "type": "figure",
      "selector": "[data-htmlx-block-id=\"deck-03-map\"]",
      "editable": true,
      "frame": { "x": 118, "y": 318, "width": 1360, "height": 456 },
      "figure": { "variant": "package-map", "cardCount": 4 }
    },
    {
      "id": "deck-04-workflow",
      "type": "figure",
      "selector": "[data-htmlx-block-id=\"deck-04-workflow\"]",
      "editable": true,
      "frame": { "x": 112, "y": 340, "width": 1368, "height": 344 },
      "figure": { "variant": "workflow-lane", "cardCount": 4 }
    },
    {
      "id": "deck-05-table",
      "type": "table",
      "selector": "[data-htmlx-block-id=\"deck-05-table\"]",
      "editable": true,
      "frame": { "x": 120, "y": 330, "width": 1360, "height": 430 },
      "table": { "columns": ["Mode", "What users see", "What changes are allowed"], "rowCount": 3 }
    }
  ],
  "constraints": {
    "scripts": false,
    "remoteResources": false,
    "coordinates": "stage-relative",
    "textScaling": "stage-uniform",
    "textFormatting": ["bold", "italic", "underline"],
    "typography": {
      "fontSize": "block-stage-relative",
      "textColor": "safe-css-color",
      "fontFamily": "package-css-or-system",
      "remoteFonts": false
    }
  }
}
