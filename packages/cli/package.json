{
  "name": "@openwebdoc/cli",
  "version": "0.1.0-alpha.0",
  "description": "Command line interface for HTMLX Document Package files.",
  "type": "module",
  "bin": {
    "htmlx": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "test": "vitest run",
    "htmlx": "node ./dist/index.js"
  },
  "dependencies": {
    "@openwebdoc/core": "workspace:*",
    "@openwebdoc/spec": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lhy0718/OpenWebDoc.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lhy0718/OpenWebDoc/issues"
  },
  "homepage": "https://github.com/lhy0718/OpenWebDoc/tree/main/packages/cli#readme",
  "keywords": [
    "openwebdoc",
    "htmlx",
    "cli",
    "document-package"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
