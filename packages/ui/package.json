{
  "name": "@openwebdoc/ui",
  "version": "0.1.0-alpha.0",
  "description": "Shared React UI components for OpenWebDoc apps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "dependencies": {
    "lucide-react": "^0.561.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lhy0718/OpenWebDoc.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/lhy0718/OpenWebDoc/issues"
  },
  "homepage": "https://github.com/lhy0718/OpenWebDoc/tree/main/packages/ui#readme",
  "keywords": [
    "openwebdoc",
    "htmlx",
    "react",
    "ui"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "./src/styles.css"
  ]
}
